DOMAIN-SUFFIX,relay.momostr.pink
DOMAIN-SUFFIX,nostr.mom
DOMAIN-SUFFIX,nos.lol
DOMAIN-SUFFIX,primal.net
DOMAIN-SUFFIX,relay.primal.net
DOMAIN-SUFFIX,nostr21.com
DOMAIN-SUFFIX,offchain.pub
DOMAIN-SUFFIX,relay.snort.social
DOMAIN-SUFFIX,middling.mydns.jp
DOMAIN-SUFFIX,nostr.middling.mydns.jp
DOMAIN-SUFFIX,inosta.cc
DOMAIN-SUFFIX,relay.nostr.inosta.cc
